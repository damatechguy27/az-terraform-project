# Copy to terraform.tfvars (gitignored) and fill in real values.
# The SSH keypair is now generated by Terraform (see keypair.tf) and the
# private key is written to ./terrakey.pem — no public key input is needed.
# Required (no defaults):
allowed_ssh_cidr = "203.0.113.42/32" # your /32 — 0.0.0.0/0 is rejected

# Optional overrides (defaults shown):
# project          = "tftest"
# environment      = "dev"
# location         = "eastus"
# cost_center      = "sandbox"
# vm_size          = "Standard_B1s"
# admin_username   = "azureuser"
# os_disk_size_gb  = 30
